# build artifacts / heavy caches
build/out/
build/cache/
build/work/
build/buildroot-*/
build/SC1000/

# compiled objects
*.o
*.d

# plugin build output (JUCE FetchContent; also covered by vst/.gitignore)
vst/build/

# local Claude Code instructions — stays local, not committed
/CLAUDE.md

# macOS
.DS_Store

# dist/ artifacts are published to the orphan 'artifacts' branch (make publish),
# NOT committed to main — keeps main's history binary-free and the repo bounded.
/dist/
