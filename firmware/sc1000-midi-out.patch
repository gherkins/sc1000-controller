@@ -486,6 +488,18 @@ void process_pic()
 	buttons[3] = !(result >> 3 & 0x01);
 	capIsTouched = (result >> 4 & 0x01);
 
+	// Continuous capsense level (the PIC's smoothed touchAverage, 10-bit) from
+	// regs 6/7 - the analog signal behind the reg-5 touch bit. Forwarded to the
+	// USB-MIDI host for smarter touch detection / margin tracing; only read
+	// when MIDI out is on, to keep the input loop at full speed otherwise.
+	if (scsettings.midiout)
+	{
+		i2c_read_address(file_i2c_pic, 0x06, &result);
+		capLevel = result;
+		i2c_read_address(file_i2c_pic, 0x07, &result);
+		capLevel |= ((unsigned int)(result & 0x03) << 8);
+	}
+
 	process_io();
 
 	// Apply volume and fader
@@ -847,6 +861,9 @@ void *SC_InputThread(void *ptr)
 
 	sleep(2);
 
+	// Bring up the USB-MIDI gadget output (Route 1 controller mode)
+	sc_midi_out_init();
+
 	int secondCount = 0;
 
 	while (1) // Main input loop
@@ -912,6 +929,9 @@ void *SC_InputThread(void *ptr)
 			}
 
