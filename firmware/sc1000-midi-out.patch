 bool capIsTouched = 0;
+unsigned int capLevel = 0; // smoothed capsense level from PIC regs 6/7 (10-bit, lower = more touch)
 unsigned char buttons[4] = {0, 0, 0, 0}, totalbuttons[4] = {0, 0, 0, 0};
 unsigned int ADCs[4] = {0, 0, 0, 0};
